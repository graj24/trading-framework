# --- LLM (required) -----------------------------------------------------------
# Pick ONE provider. Default config.yaml uses Groq:
GROQ_API_KEY=

# Optional alternate providers — litellm picks the right one based on the
# `llm.model` string in config.yaml (e.g. `openai/gpt-4o-mini`,
# `anthropic/claude-3-5-sonnet-20241022`, `bedrock/anthropic.claude-3-haiku`).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AWS — only needed if you use a `bedrock/...` model.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Live data (recommended for intraday) ------------------------------------
# Apply at https://groww.in/user/profile/trading-apis (free).
GROWW_API_KEY=
GROWW_SECRET=
GROWW_TOTP_SECRET=
# Access tokens are valid ~daily. Re-run `python -m core.groww_client` to
# refresh, or paste a fresh one here.
GROWW_ACCESS_TOKEN=

# --- Twitter (optional, currently UNUSED in the live path) -------------------
# DiscoveryAgent uses Nitter scraping; these keys are reserved for a future
# upgrade. Leave blank if you don't have them.
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- Telegram alerts (optional) ----------------------------------------------
# Create a bot via @BotFather, then start a DM with it and send any message;
# fetch your chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Zerodha (only required when trading.mode = live) ------------------------
# https://kite.trade/docs/connect/v3/install/
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# --- Ripple sentiment subsystem (optional override) --------------------------
# Where StockSentimentPipeline writes JSON. Defaults to `<repo>/output`.
# OUTPUT_DIR=
# DEFAULT_MAX_TWEETS=10
