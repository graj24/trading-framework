# Anthropic / OpenAI
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Langfuse Cloud (https://cloud.langfuse.com)
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Postgres (control plane DB; populated by docker-compose in Step 1.2)
POSTGRES_URL=postgresql+asyncpg://agora:agora@localhost:5432/agora

# Temporal (populated by docker-compose in Step 1.2)
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Letta server (populated by docker-compose in Step 1.2)
LETTA_HOST=http://localhost:8283

# Qdrant (populated by docker-compose in Step 1.2)
QDRANT_HOST=http://localhost:6333

# Default LLM models (override per-agent at runtime)
AGORA_DEFAULT_REASONING_MODEL=anthropic/claude-sonnet-4-5
AGORA_DEFAULT_CHEAP_MODEL=anthropic/claude-haiku-4-5

# AGORA workspace root (defaults to repo dir)
AGORA_WORKSPACE_ROOT=
